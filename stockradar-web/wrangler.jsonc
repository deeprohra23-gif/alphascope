{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "alphascope",
  "main": "worker.js",
  "compatibility_date": "2026-07-07",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "public",
    "binding": "ASSETS"
  }
}
